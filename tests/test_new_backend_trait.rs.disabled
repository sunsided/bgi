//! Backend trait contract tests
//!
//! These tests verify that all backend implementations conform to the Backend trait
//! contract and provide consistent behavior across different backends.

use bgi::backend::{Backend, GraphicsMode, Color, KeyEvent, MouseEvent, KeyCode, MouseButton, KeyModifiers};

/// Test that backend trait exists and has required methods
#[test]
fn test_backend_trait_contract() {
    // This test will fail until Backend trait is properly implemented

    // Test that we can create a mock backend that implements the trait
    struct MockBackend {
        initialized: bool,
        mode: Option<GraphicsMode>,
        pixels: Vec<Vec<Color>>,
        input_events: Vec<String>,
    }

    impl Backend for MockBackend {
        type Error = String;

        fn init_graphics(&mut self, mode: GraphicsMode) -> Result<(), Self::Error> {
            if mode.width == 0 || mode.height == 0 {
                return Err("Invalid graphics mode".to_string());
            }
            self.initialized = true;
            self.mode = Some(mode);
            self.pixels = vec![vec![Color::BLACK; mode.width as usize]; mode.height as usize];
            Ok(())
        }

        fn close_graphics(&mut self) {
            self.initialized = false;
            self.mode = None;
            self.pixels.clear();
        }

        fn set_pixel(&mut self, x: i16, y: i16, color: Color) {
            if let Some(mode) = self.mode {
                if x >= 0 && y >= 0 && (x as u16) < mode.width && (y as u16) < mode.height {
                    self.pixels[y as usize][x as usize] = color;
                }
            }
        }

        fn get_pixel(&self, x: i16, y: i16) -> Color {
            if let Some(mode) = self.mode {
                if x >= 0 && y >= 0 && (x as u16) < mode.width && (y as u16) < mode.height {
                    return self.pixels[y as usize][x as usize];
                }
            }
            Color::BLACK
        }

        fn flush(&mut self) {
            // Mock implementation - just mark that flush was called
        }

        fn is_initialized(&self) -> bool {
            self.initialized
        }

        fn get_mode_info(&self) -> Option<GraphicsMode> {
            self.mode
        }

        fn poll_keyboard(&mut self) -> Option<KeyEvent> {
            None // Mock - no events
        }

        fn has_keyboard_input(&self) -> bool {
            false // Mock - no input
        }

        fn poll_mouse(&mut self) -> Option<MouseEvent> {
            None // Mock - no events
        }

        fn get_mouse_position(&self) -> (i16, i16) {
            (0, 0) // Mock position
        }

        fn should_close(&self) -> bool {
            false // Mock - never close
        }
    }

    let mut backend = MockBackend {
        initialized: false,
        mode: None,
        pixels: Vec::new(),
        input_events: Vec::new(),
    };

    // Test initialization
    assert!(!backend.is_initialized());

    let mode = GraphicsMode {
        width: 640,
        height: 480,
        colors: 16,
        mode_id: 1,
    };

    backend.init_graphics(mode).expect("Graphics initialization should succeed");
    assert!(backend.is_initialized());
    assert_eq!(backend.get_mode_info(), Some(mode));

    // Test pixel operations
    backend.set_pixel(10, 20, Color::WHITE);
    assert_eq!(backend.get_pixel(10, 20), Color::WHITE);

    // Test bounds checking
    assert_eq!(backend.get_pixel(-1, -1), Color::BLACK);
    assert_eq!(backend.get_pixel(1000, 1000), Color::BLACK);

    // Test input interface
    assert!(!backend.has_keyboard_input());
    assert_eq!(backend.poll_keyboard(), None);
    assert_eq!(backend.poll_mouse(), None);
    assert_eq!(backend.get_mouse_position(), (0, 0));
    assert!(!backend.should_close());

    // Test cleanup
    backend.close_graphics();
    assert!(!backend.is_initialized());
}

/// Test that GraphicsMode validation works correctly
#[test]
fn test_graphics_mode_validation() {
    struct TestBackend;

    impl Backend for TestBackend {
        type Error = &'static str;

        fn init_graphics(&mut self, mode: GraphicsMode) -> Result<(), Self::Error> {
            if mode.width == 0 || mode.height == 0 {
                Err("Invalid dimensions")
            } else {
                Ok(())
            }
        }

        fn close_graphics(&mut self) {}
        fn set_pixel(&mut self, _x: i16, _y: i16, _color: Color) {}
        fn get_pixel(&self, _x: i16, _y: i16) -> Color { Color::BLACK }
        fn flush(&mut self) {}
        fn is_initialized(&self) -> bool { false }
        fn get_mode_info(&self) -> Option<GraphicsMode> { None }
        fn poll_keyboard(&mut self) -> Option<KeyEvent> { None }
        fn has_keyboard_input(&self) -> bool { false }
        fn poll_mouse(&mut self) -> Option<MouseEvent> { None }
        fn get_mouse_position(&self) -> (i16, i16) { (0, 0) }
        fn should_close(&self) -> bool { false }
    }

    let mut backend = TestBackend;

    // Valid mode should succeed
    let valid_mode = GraphicsMode { width: 640, height: 480, colors: 16, mode_id: 1 };
    assert!(backend.init_graphics(valid_mode).is_ok());

    // Invalid modes should fail
    let invalid_mode = GraphicsMode { width: 0, height: 480, colors: 16, mode_id: 1 };
    assert!(backend.init_graphics(invalid_mode).is_err());
}

/// Test color constants and BGI compatibility
#[test]
fn test_color_constants() {
    // Verify BGI color constants exist and have correct values
    assert_eq!(Color::BLACK.bgi_index, 0);
    assert_eq!(Color::BLUE.bgi_index, 1);
    assert_eq!(Color::GREEN.bgi_index, 2);
    assert_eq!(Color::CYAN.bgi_index, 3);
    assert_eq!(Color::RED.bgi_index, 4);
    assert_eq!(Color::MAGENTA.bgi_index, 5);
    assert_eq!(Color::BROWN.bgi_index, 6);
    assert_eq!(Color::LIGHTGRAY.bgi_index, 7);
    assert_eq!(Color::DARKGRAY.bgi_index, 8);
    assert_eq!(Color::LIGHTBLUE.bgi_index, 9);
    assert_eq!(Color::LIGHTGREEN.bgi_index, 10);
    assert_eq!(Color::LIGHTCYAN.bgi_index, 11);
    assert_eq!(Color::LIGHTRED.bgi_index, 12);
    assert_eq!(Color::LIGHTMAGENTA.bgi_index, 13);
    assert_eq!(Color::YELLOW.bgi_index, 14);
    assert_eq!(Color::WHITE.bgi_index, 15);

    // Verify RGB values for key colors
    assert_eq!(Color::BLACK, Color { r: 0, g: 0, b: 0, bgi_index: 0 });
    assert_eq!(Color::WHITE, Color { r: 255, g: 255, b: 255, bgi_index: 15 });
    assert_eq!(Color::RED, Color { r: 255, g: 0, b: 0, bgi_index: 4 });
    assert_eq!(Color::GREEN, Color { r: 0, g: 255, b: 0, bgi_index: 2 });
    assert_eq!(Color::BLUE, Color { r: 0, g: 0, b: 255, bgi_index: 1 });
}

/// Test input event types and BGI key code conversion
#[test]
fn test_input_event_types() {
    // Test KeyCode BGI conversion
    assert_eq!(KeyCode::Ascii(b'A').to_bgi_code(), b'A');
    assert_eq!(KeyCode::Enter.to_bgi_code(), 13);
    assert_eq!(KeyCode::Escape.to_bgi_code(), 27);
    assert_eq!(KeyCode::Backspace.to_bgi_code(), 8);

    // Test extended key detection
    assert!(KeyCode::F1.is_extended());
    assert!(KeyCode::Up.is_extended());
    assert!(!KeyCode::Ascii(b'A').is_extended());
    assert!(!KeyCode::Enter.is_extended());

    // Test event construction
    let key_event = KeyEvent {
        key_code: KeyCode::Ascii(b'A'),
        ascii_code: b'A',
        is_pressed: true,
        modifiers: KeyModifiers { shift: false, ctrl: false, alt: false },
    };
    assert_eq!(key_event.ascii_code, b'A');
    assert!(key_event.is_pressed);

    let mouse_event = MouseEvent {
        x: 100,
        y: 200,
        button: MouseButton::Left,
        is_pressed: true,
    };
    assert_eq!(mouse_event.x, 100);
    assert_eq!(mouse_event.y, 200);
    assert_eq!(mouse_event.button, MouseButton::Left);
}

